rules_version = '2';

// Reglas de seguridad de Firestore para homeloan-app.
//
// Arquitectura:
// - El webhook (servidor) usa Firebase Admin SDK y bypasea estas reglas.
// - El CRM (navegador) usa el Client SDK y está sujeto a estas reglas.
// - Solo usuarios autenticados vía Firebase Auth acceden al CRM.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── solicitudes: leads del CRM ──────────────────────────────
    match /solicitudes/{docId} {
      allow read:            if request.auth != null;
      allow update, delete:  if request.auth != null;
      allow create:          if false;  // solo Admin SDK (webhook) crea leads
    }

    // ── whatsapp_sessions: historial del chatbot ────────────────
    // Los agentes necesitan leer la conversación en el CRM.
    // Escrituras: exclusivamente el servidor (Admin SDK).
    // EXCEPCIÓN: agentes autenticados pueden modificar SOLO los campos de
    // control (pausa/reactivación del bot, contadores de mensajes leídos)
    // sin poder tocar el historial `messages`.
    match /whatsapp_sessions/{docId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['agentPausedUntil', 'unreadCount', 'lastReadAt', 'lastReadBy']);
      allow create, delete: if false;
    }

    // ── Denegar todo lo demás por defecto ───────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
